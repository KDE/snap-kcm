#: src/snapbackend.cpp:287
#, kde-format
msgid "No error"
msgstr "Žiadna chyba"

#: src/snapbackend.cpp:290
#, kde-format
msgid "Unknown error occurred"
msgstr "Vyskytla sa neznáma chyba"

#: src/snapbackend.cpp:293
#, kde-format
msgid "Not able to connect to snapd"
msgstr "Nie je možné pripojiť sa k snapd"

#: src/snapbackend.cpp:296
#, kde-format
msgid "An error occurred while writing to snapd"
msgstr "Pri zápise do snapd sa vyskytla chyba"

#: src/snapbackend.cpp:299
#, kde-format
msgid "An error occurred while reading from snapd"
msgstr "Pri čítaní zo snapd sa vyskytla chyba"

#: src/snapbackend.cpp:302
#, kde-format
msgid "Snapd did not understand the request that was sent"
msgstr "Snapd nerozumel odoslanej požiadavke"

#: src/snapbackend.cpp:305
#, kde-format
msgid "The response received from snapd was not understood"
msgstr "Odpoveď prijatá od snapd nebola zrozumiteľná"

#: src/snapbackend.cpp:308
#, kde-format
msgid "The requested operation requires super user password"
msgstr "Požadovaná operácia vyžaduje heslo superpoužívateľa"

#: src/snapbackend.cpp:311
#, kde-format
msgid "The provided super user password is invalid"
msgstr "Zadané heslo superpoužívateľa je neplatné"

#: src/snapbackend.cpp:314
#, kde-format
msgid "Login requires a two-factor code"
msgstr "Prihlásenie vyžaduje dvojfaktorový kód"

#: src/snapbackend.cpp:317
#, kde-format
msgid "The two-factor code provided at login is invalid"
msgstr "Dvojfaktorový kód zadaný pri prihlásení je neplatný"

#: src/snapbackend.cpp:320
#, kde-format
msgid "This user account is not permitted to perform the requested operation"
msgstr "Tento používateľský účet nemá povolenie vykonať požadovanú operáciu"

#: src/snapbackend.cpp:323
#, kde-format
msgid "An unspecified error occurred while communicating with snapd"
msgstr "Pri komunikácii so snapd sa vyskytla nešpecifikovaná chyba"

#: src/snapbackend.cpp:326
#, kde-format
msgid "This user has not accepted the store’s terms of service"
msgstr "Tento používateľ neprijal podmienky služby obchodu"

#: src/snapbackend.cpp:329
#, kde-format
msgid "This user has not configured a payment method"
msgstr "Tento používateľ nemá nastavenú platobnú metódu"

#: src/snapbackend.cpp:332
#, kde-format
msgid "This user has had their payment method declined by the payment provider"
msgstr ""
"Platobná metóda tohto používateľa bola poskytovateľom platieb zamietnutá"

#: src/snapbackend.cpp:335
#, kde-format
msgid "The requested snap is already installed"
msgstr "Požadovaný snap je už nainštalovaný"

#: src/snapbackend.cpp:338
#, kde-format
msgid "The requested snap is not installed"
msgstr "Požadovaný snap nie je nainštalovaný"

#: src/snapbackend.cpp:341
#, kde-format
msgid "No update is available for this snap"
msgstr "Pre tento snap nie je dostupná žiadna aktualizácia"

#: src/snapbackend.cpp:344
#, kde-format
msgid "Provided password is not valid"
msgstr "Zadané heslo nie je platné"

#: src/snapbackend.cpp:347
#, kde-format
msgid "This snap needs to be installed using devmode"
msgstr "Tento snap je potrebné nainštalovať pomocou režimu devmode"

#: src/snapbackend.cpp:350
#, kde-format
msgid "This snap needs to be installed using classic mode"
msgstr "Tento snap je potrebné nainštalovať pomocou klasického režimu"

#: src/snapbackend.cpp:353
#, kde-format
msgid "A classic system is required to install this snap"
msgstr "Na inštaláciu tohto snapu je potrebný klasický systém"

#: src/snapbackend.cpp:356
#, kde-format
msgid "Operation was cancelled"
msgstr "Operácia bola zrušená"

#: src/snapbackend.cpp:359
#, kde-format
msgid "A bad query was provided"
msgstr "Bol zadaný nesprávny dotaz"

#: src/snapbackend.cpp:362
#, kde-format
msgid "A timeout occurred during the request"
msgstr "Počas požiadavky vypršal časový limit"

#: src/snapbackend.cpp:365
#, kde-format
msgid "The requested snap couldn’t be found"
msgstr "Požadovaný snap sa nepodarilo nájsť"

#: src/snapbackend.cpp:368
#, kde-format
msgid "The requested snap is not in the store"
msgstr "Požadovaný snap sa nenachádza v obchode"

#: src/snapbackend.cpp:371
#, kde-format
msgid "Authentication was cancelled by the user"
msgstr "Overenie bolo zrušené používateľom"

#: src/snapbackend.cpp:374
#, kde-format
msgid "Snap not compatible with classic mode"
msgstr "Snap nie je kompatibilný s klasickým režimom"

#: src/snapbackend.cpp:377
#, kde-format
msgid "Requested snap revision not available"
msgstr "Požadovaná revízia snapu nie je dostupná"

#: src/snapbackend.cpp:380
#, kde-format
msgid "Requested snap channel not available"
msgstr "Požadovaný kanál snapu nie je dostupný"

#: src/snapbackend.cpp:383
#, kde-format
msgid "The given snap or directory does not look like a snap"
msgstr "Zadaný snap alebo priečinok nevyzerá ako snap"

#: src/snapbackend.cpp:386
#, kde-format
msgid "A hostname failed to resolve during the request"
msgstr "Počas požiadavky sa nepodarilo rozlíšiť názov hostiteľa"

#: src/snapbackend.cpp:389
#, kde-format
msgid "A requested configuration option is not set"
msgstr "Požadovaná konfiguračná možnosť nie je nastavená"

#: src/snapbackend.cpp:392
#, kde-format
msgid "The requested app couldn't be found"
msgstr "Požadovanú aplikáciu sa nepodarilo nájsť"

#: src/snapbackend.cpp:395
#, kde-format
msgid "No snap revision on specified architecture"
msgstr "Žiadna revízia snapu na zadanej architektúre"

#: src/snapbackend.cpp:398
#, kde-format
msgid "The requested operation would conflict with currently ongoing change"
msgstr "Požadovaná operácia by bola v konflikte s prebiehajúcou zmenou"

#: src/snapbackend.cpp:401
#, kde-format
msgid "The requested interface has not changed"
msgstr "Požadované rozhranie sa nezmenilo"

#: src/snapbackend.cpp:404
#, kde-format
msgid "Unknown error code"
msgstr "Neznámy kód chyby"

#: src/ui/ErrorDialog.qml:18
#, kde-format
msgid "Error"
msgstr "Chyba"

#: src/ui/main.qml:28
#, kde-format
msgid "Snap Applications"
msgstr "Aplikácie Snap"

#: src/ui/main.qml:49
#, kde-format
msgid "Install snaps to change the permissions"
msgstr "Nainštalujte snapy na zmenu povolení"

#: src/ui/permissions.qml:20
#, kde-format
msgid "Permissions"
msgstr "Práva"

#: src/ui/permissions.qml:20
#, kde-format
msgid "Permissions for %1"
msgstr "Oprávnenia pre %1"

#: src/ui/permissions.qml:24
#, kde-format
msgid "Select an application from the list to view its permissions here"
msgstr "Vybrať aplikáciu zo zoznamu a zobraziť tu jej oprávnenia"
